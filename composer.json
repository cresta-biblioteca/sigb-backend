{
  "name": "sigb/api-cresta",
  "description": "Sistema de Gestión Bibliotecaria - API",
  "type": "project",
  "require": {
    "php": "^8.3",
    "ext-pdo": "*",
    "ext-mysqli": "*",
    "ext-json": "*",
    "vlucas/phpdotenv": "^5.6",
    "bramus/router": "^1.6",
    "firebase/php-jwt": "^7.0",
    "robmorgan/phinx": "^0.16"
  },
  "require-dev": {
    "fakerphp/faker": "^1.23",
    "mockery/mockery": "^1.6",
    "pestphp/pest": "^2.34",
    "phpunit/phpunit": "^10.5",
    "squizlabs/php_codesniffer": "^4.0"
  },
  "autoload": {
    "psr-4": {
      "App\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Tests\\": "tests/"
    }
  },
  "scripts": {
    "test": "pest",
    "test:unit": "pest --filter=Unit",
    "test:integration": "pest --filter=Integration",
    "test:coverage": "pest --coverage",
    "migrate": "vendor/bin/phinx migrate",
    "migrate:rollback": "vendor/bin/phinx rollback",
    "migrate:create": "vendor/bin/phinx create",
    "lint": "phpcs --standard=PSR12 src/",
    "lint:fix": "phpcbf --standard=PSR12 src/"
  },
  "config": {
    "allow-plugins": {
      "pestphp/pest-plugin": true
    },
    "optimize-autoloader": true,
    "preferred-install": "dist",
    "sort-packages": true
  },
  "minimum-stability": "stable",
  "prefer-stable": true
}
